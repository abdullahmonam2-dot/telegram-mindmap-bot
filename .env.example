# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Database URL (SQLite default)
DATABASE_URL=sqlite+aiosqlite:///./data/bot_database.db

# Admin User ID (Optional, for notifications)
ADMIN_ID=123456789

# Default Arabic Voice for edge-tts (e.g., ar-EG-SalmaNeural, ar-SA-ZariyahNeural)
DEFAULT_ARABIC_VOICE=ar-EG-SalmaNeural
